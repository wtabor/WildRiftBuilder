{
  "name": "wildriftbuilder",
  "version": "0.1.0",
  "private": true,
  "description": "An accurate, current, interactive stat & build calculator for League of Legends: Wild Rift.",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-data": "tsx scripts/validate.ts",
    "smoke": "node scripts/smoke.mjs",
    "verify-data": "node scripts/verify-data.mjs"
  },
  "dependencies": {
    "geist": "^1.7.2",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
